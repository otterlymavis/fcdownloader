{
  "name": "fcdownloader",
  "version": "1.5.10",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "pack:extension": "node scripts/pack-extension.mjs",
    "bake:web": "node scripts/bake-web-config.mjs",
    "dist:companion": "npm --prefix desktop-companion run dist",
    "dist:companion:nobrowser-go": "npm --prefix desktop-companion run variants:nobrowser-go",
    "test:companion:nobrowser-go": "npm --prefix desktop-companion run test:nobrowser-go"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-cookies/cookies": "^6.2.1",
    "expo": "~55.0.26",
    "expo-build-properties": "~55.0.14",
    "expo-file-system": "~55.0.22",
    "expo-linking": "~55.0.15",
    "expo-media-library": "~55.0.17",
    "expo-sharing": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-video": "~55.0.17",
    "fast-xml-parser": "^5.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "adm-zip": "^0.5.17",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "@react-native-cookies/cookies"
        ],
        "listUnknownPackages": true
      }
    }
  },
  "private": true
}
