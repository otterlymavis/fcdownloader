{
  "name": "fcdownloader-companion",
  "version": "0.2.0",
  "description": "FCDownloader desktop companion for local YouTube HD downloads.",
  "author": "FCDownloader",
  "main": "src/main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "helper:build": "node scripts/build-helper.cjs",
    "pack": "npm run helper:build && node scripts/build-electron.cjs --dir",
    "dist": "npm run helper:build && node scripts/build-electron.cjs"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.fcdownloader.companion",
    "productName": "FCDownloader Companion",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/helper",
        "to": "fcdownloader/bin",
        "filter": [
          "fcdownloader-local-helper*"
        ]
      },
      {
        "from": "../scripts",
        "to": "fcdownloader/scripts",
        "filter": [
          "local-youtube-helper.py"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "src/entitlements.mac.plist",
      "entitlementsInherit": "src/entitlements.mac.plist",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
