# Copy to .env.local and fill in your own values. `.env.local` is gitignored
# (see .gitignore line 38). Never commit real values to .env.example itself.

# ── Mobile app (Expo) ────────────────────────────────────────────────────────

# Personal EAS project ID. Run `eas init` in this directory to create one and
# Expo will write it into eas.json + here.
# EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Public-facing HD extractor backend (Fly.io / Cloudflare / your own host
# running server/main.py). Inlined into the APK at build time.
# EXPO_PUBLIC_EXTRACTOR_URL=https://your-app.fly.dev

# Optional bearer token clients send to bypass the per-IP rate limit. Set the
# same value as TRUSTED_TOKEN on the server. Leave blank for unauthenticated.
# EXPO_PUBLIC_EXTRACTOR_TOKEN=

# ── Server (server/) — these are Fly.io secrets, not committed env vars. ────
#
# fly secrets set YT_COOKIES_BASE64="$(base64 -w0 cookies.txt)" -a your-app
# fly secrets set ALLOWED_ORIGINS="https://yourdomain.com,chrome-extension://..."
# fly secrets set TRUSTED_TOKEN="$(openssl rand -hex 32)"   # optional
# fly secrets set RATE_LIMIT="30/minute;300/hour;1500/day"  # optional

# ── GitHub Actions (CI) ──────────────────────────────────────────────────────
#
# Set in repo Settings → Secrets and variables → Actions:
#   RELEASE_KEYSTORE_BASE64  - base64-encoded android signing keystore (required)
#   EXPO_PUBLIC_EXTRACTOR_URL - same value as above (required for backend-version)
