{
  "cli": {
    "version": ">= 16.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "simulator": {
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "local-only": {
      "extends": "production",
      "channel": "local-only",
      "env": {
        "FCDL_ALLOW_INSECURE_HTTP": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-local-only": {
      "extends": "preview",
      "env": {
        "FCDL_ALLOW_INSECURE_HTTP": "1"
      }
    }
  }
}
