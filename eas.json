{
  "cli": {
    "version": ">= 16.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "simulator": {
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      }
    },
    "local-only": {
      "extends": "production",
      "channel": "local-only",
      "env": {
        "EXPO_PUBLIC_EXTRACTOR_URL": "",
        "EXPO_PUBLIC_EXTRACTOR_TOKEN": ""
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-local-only": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_EXTRACTOR_URL": "",
        "EXPO_PUBLIC_EXTRACTOR_TOKEN": ""
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your@apple.id",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_TEAM_ID"
      }
    }
  }
}
