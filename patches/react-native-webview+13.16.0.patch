+                    "event:'MEDIA_DETECTED'," +
+                    "url:u," +
+                    "pageUrl:location.href," +
+                    "userAgent:navigator.userAgent," +
+                    "mimeType:null," +
+                    "mediaType:t," +
+                    "timestamp:Date.now()," +
+                    "source:'native'" +
+                    "}));" +
+                    "}catch(e){}" +
+                    "})();";
+                view.evaluateJavascript(js, null);
+            }
+        });
+    }
