+    private void maybeEmitCapturedUrl(final WebView view, final String url) {
+        if (!shouldLogUrl(url)) return;
+        sMainHandler.post(new Runnable() {
+            @Override
+            public void run() {
+                String quotedUrl = JSONObject.quote(url);
+                String js =
+                    "(function(){" +
+                    "try{" +
+                    "if(!window.ReactNativeWebView)return;" +
+                    "if(window.__rn_fcd_native_log_seen===undefined)window.__rn_fcd_native_log_seen=new Set();" +
+                    "var u=" + quotedUrl + ";" +
+                    "if(window.__rn_fcd_native_log_seen.has(u))return;" +
+                    "window.__rn_fcd_native_log_seen.add(u);" +
+                    "window.ReactNativeWebView.postMessage(JSON.stringify({" +
+                    "event:'URL_CAPTURED'," +
+                    "url:u," +
+                    "timestamp:Date.now()," +
