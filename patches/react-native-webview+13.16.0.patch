+    // ── Native-level request interception for video stream detection ──────────
+    // Called by Android for EVERY resource request (including native <video> playback).
+    // JS injection alone misses these because WebKit's media engine requests them
+    // outside the JavaScript context.
+    private static final Handler sMainHandler = new Handler(Looper.getMainLooper());
+
+    @TargetApi(Build.VERSION_CODES.LOLLIPOP)
+    @Override
+    public WebResourceResponse shouldInterceptRequest(WebView view, WebResourceRequest request) {
+        final String url = request.getUrl().toString();
+        final java.util.Map<String, String> headers = request.getRequestHeaders();
+        maybeEmitCapturedUrl(view, url);
+        maybeEmitVideoUrl(view, url, headers != null ? headers.get("Accept") : null);
+        return super.shouldInterceptRequest(view, request);
+    }
+
+    private static boolean shouldLogUrl(String url) {
+        String u = url.toLowerCase(java.util.Locale.ROOT);
+        if (u.length() < 12 || u.startsWith("blob:") || u.startsWith("data:") || u.startsWith("file:")) return false;
+        return !u.matches(".*\\.(png|jpe?g|gif|svg|ico|webp|avif|woff2?|ttf|eot|otf|css|js|mjs|map)(\\?.*)?$");
+    }
+
+    private static boolean looksLikeVideo(String url, String accept) {
+        String u = url.toLowerCase(java.util.Locale.ROOT);
+        // URL-extension heuristics
+        if (u.contains(".m3u8") || u.contains(".mpd")) return true;
+        if (u.matches(".*\\.ts(\\?.*)?$") || u.contains(".m4s") || u.contains(".mp4")) return true;
+        // MIME / Accept-header heuristics
+        if (accept != null) {
+            String a = accept.toLowerCase(java.util.Locale.ROOT);
+            if (a.contains("mpegurl") || a.contains("dash") || a.contains("video/") ||
+                a.contains("audio/") || a.contains("m3u8")) return true;
+        }
+        // Common manifest path patterns (no extension)
+        if (u.matches(".*/?(master|playlist|manifest|index|stream)(\\.|\\?|/|$).*") &&
+            !u.matches(".*\\.(html?|js|css|json|woff2?|png|jpe?g|gif|svg)(\\?.*)?$")) return true;
+        return false;
+    }
