# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Signing keystores — debug is shared/safe, anything else is a credential.
*.keystore
!**/debug.keystore

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated iOS folder (regenerated by expo prebuild + plugins/withMediaMuxer.js)
/ios

# Android: keep the folder + custom native modules in git, exclude build artifacts.
android/build/
android/app/build/
android/.gradle/
android/.idea/
android/captures/
android/local.properties
android/app/release/
android/app/debug/
android/keystores/
*.iml

# Built APKs / bundles
*.apk
*.aab

# Python venvs (server/)
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc

# Server local test artifacts
server/_extract_test*.json
server/cookies.txt
server/cookies.b64

# Companion generated helper binary and PyInstaller work dirs
desktop-companion/build/helper/
desktop-companion/build/electron-cache/
desktop-companion/build/electron-builder-cache/
desktop-companion/build/pyinstaller-venv/
desktop-companion/build/pyinstaller-work/
desktop-companion/build/pyinstaller-spec/

#  Code local settings
./



